# Normalize line endings to LF in the repository regardless of OS,
# so switching between macOS and Windows doesn't produce noisy diffs.
* text=auto eol=lf

# Windows batch files need CRLF to run reliably.
*.bat text eol=crlf

# Binary files - never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.pptx binary
*.pkl binary
*.tflite binary
*.onnx binary
*.p12 binary
